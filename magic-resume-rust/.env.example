# Server Configuration
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=3000

# Database Configuration
APP_DATABASE_URL=sqlite://./magic_resume.db
APP_DATABASE_MAX_CONNECTIONS=10

